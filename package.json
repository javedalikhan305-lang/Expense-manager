{
  "name": "expense-manager",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm --prefix client run dev\" \"npm --prefix server run dev\"",
    "build": "cd client && npm run build",
    "start": "cd server && npm run start"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
